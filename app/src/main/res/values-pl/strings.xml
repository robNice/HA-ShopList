    <string name="offline_dialog_title">Tryb offline</string>
    <string name="offline_dialog_text">Aktualna lista pozostaje dostępna i możesz ją dalej edytować. Twoje zmiany zostaną zsynchronizowane automatycznie, gdy Home Assistant znów będzie osiągalny.</string>
